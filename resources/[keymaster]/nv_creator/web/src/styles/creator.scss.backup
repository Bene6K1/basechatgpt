@use '@/styles/utils.scss' as *;

.creator {
  margin-left: vh(60);
  margin-bottom: vh(123);
  width: vh(520);
  height: fit-content;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: vh(20);
  color: white;
  text-shadow: 0 0 vh(4) rgba(0, 0, 0, 0.25);

  &__bar {
    width: 100%;
    height: vh(96);
    padding: vh(15);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: vh(8);

    &-item {
      flex: 1;
      height: 100%;
      background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
      border-radius: vh(4);
      border: vh(1) solid rgba(109, 109, 109, 0.5);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: vh(8);
      padding: vh(10);
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      filter: brightness(70%);
      cursor: pointer;

      &:hover {
        background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
        border: vh(1) solid rgb(105, 8, 29);
        filter: brightness(100%);
        transform: scale(1.04);
      }

      &:active {
        filter: brightness(70%);
        transform: scale(0.95);
      }

      &--icon {
        font-size: vh(18);
      }

      &--label {
        font-size: vh(10);
        font-weight: 500;
      }
    }

    &-item--active {
      background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
      border: vh(1) solid rgb(105, 8, 29);
      filter: brightness(100%);
    }
  }

  &__content {
    width: 100%;
    height: vh(612);
    padding: vh(30);
    display: flex;
    flex-direction: column;
    gap: vh(10);

    &-page {
      font-size: vh(12);
      font-weight: 500;
    }
  }

  &__actions {
    width: 100%;
    height: vh(95);
    padding: vh(30);
    display: flex;
    align-items: center;
    gap: vh(10);
    padding: vh(15);

    &-item {
      flex: 1;
      height: 100%;
      background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
      border-radius: vh(4);
      border: vh(1) solid rgba(109, 109, 109, 0.5);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: vh(8);
      padding: vh(10);
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      filter: brightness(70%);
      cursor: pointer;

      &:hover {
        background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
        border: vh(1) solid rgb(105, 8, 29);
        filter: brightness(100%);
        transform: scale(1.04);
      }

      &:active {
        filter: brightness(70%);
        transform: scale(0.95);
      }

      &--icon {
        font-size: vh(18);
      }

      &--label {
        font-size: vh(10);
        font-weight: 500;
      }

      &.disabled {
        pointer-events: none !important;
      }
    }
  }
}

// gender
.gender {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: vh(5);

  &__title {
    font-size: vh(16);
    font-weight: 500;
    color: white;
  }

  &__genders {
    width: 100%;
    height: vh(125);
    display: flex;
    gap: vh(10);

    &-item {
      flex: 1;
      height: 100%;
      background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
      border-radius: vh(4);
      border: vh(1) solid rgba(109, 109, 109, 0.5);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: vh(8);
      padding: vh(10);
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      filter: brightness(70%);
      cursor: pointer;
      font-size: vh(18);

      &:hover {
        background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
        border: vh(1) solid rgb(105, 8, 29);
        filter: brightness(100%);
        transform: scale(1.05);
      }

      &:active {
        filter: brightness(70%);
        transform: scale(0.95);
      }
    }

    &-item--active {
      background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
      border: vh(1) solid rgb(105, 8, 29);
      filter: brightness(100%);
    }
  }
}

// visage / apparence
.visage,
.apparence {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: vh(10);

  &__categories {
    width: 100%;
    height: vh(54);
    display: flex;
    justify-content: space-between;
    align-items: center;

    &-item {
      width: vh(60);
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
      border-radius: vh(4);
      border: vh(1) solid rgba(109, 109, 109, 0.5);
      font-size: vh(12);
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      filter: brightness(70%);
      cursor: pointer;

      &:hover {
        background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
        border: vh(1) solid rgb(105, 8, 29);
        filter: brightness(100%);
        transform: scale(1.04);
      }

      &:active {
        filter: brightness(70%);
        transform: scale(0.95);
      }

      img {
        width: 90%;
        height: 90%;
        object-fit: contain;
      }
    }

    &-item--active {
      background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
      border: vh(1) solid rgb(105, 8, 29);
      filter: brightness(100%);
    }
  }

  &__components {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: vh(10);

    &-label {
      font-size: vh(16);
      font-weight: 500;
      color: white;
    }
  }

  &__color-picker {
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: vh(5.6);
    overflow-x: auto;
    overflow-y: hidden;
    padding-top: vh(10);

    .picker-swatch {
      width: vh(26);
      height: vh(26);
      border-radius: vh(2);
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      filter: brightness(50%);
      cursor: pointer;

      &:hover {
        filter: brightness(100%);
        transform: scale(1.15);
      }

      &:active {
        filter: brightness(50%);
        transform: scale(0.85);
      }

      &.selected {
        filter: brightness(100%);
        transform: scale(1.15);
      }
    }
  }
}

// heritage
.heritage {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: vh(10);

  &__parents {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: vh(10);

    &-parent {
      position: relative;
      width: vh(200);
      height: vh(145);
      background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
      border-radius: vh(4);
      border: vh(1) solid rgba(109, 109, 109, 0.5);
      display: grid;
      align-items: center;
      justify-items: center;

      img {
        width: vh(145);
        height: 100%;
        object-fit: contain;
      }
    }

    &-type {
      flex: 1;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;

      &-item {
        height: vh(45);
        background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
        border-radius: vh(4);
        border: vh(1) solid rgba(109, 109, 109, 0.5);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: vh(8);
        padding: vh(10);
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        filter: brightness(70%);
        cursor: pointer;
        font-size: vh(12);
        font-weight: 500;
        color: white;

        &:hover {
          background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
          border: vh(1) solid rgb(105, 8, 29);
          filter: brightness(100%);
          transform: scale(1.02);
        }

        &:active {
          filter: brightness(70%);
          transform: scale(0.98);
        }
      }

      &-item--active {
        background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
        border: vh(1) solid rgb(105, 8, 29);
        filter: brightness(100%);
      }
    }
  }

  &__slider {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: vh(10);

    &-arrow {
      width: vh(80);
      height: vh(40);
      background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
      border-radius: vh(4);
      border: vh(1) solid rgba(109, 109, 109, 0.5);
      border-radius: vh(4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: vh(12);
      color: white;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;

      &:hover {
        background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
        border: vh(1) solid rgb(105, 8, 29);
        transform: scale(1.04);
      }

      &:active {
        transform: scale(0.95);
      }
    }

    &-arrow--active {
      background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
      border: vh(1) solid rgb(105, 8, 29);
      filter: brightness(100%);
    }

    &-value {
      flex: 1;
      height: vh(40);
      background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
      border-radius: vh(4);
      border: vh(1) solid rgba(109, 109, 109, 0.5);
      border-radius: vh(4);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: vh(12);
    }
  }
}

// vetement
.clothes {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: vh(10);

  &__item {
    flex: 1;
    background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
    border: vh(1) solid rgba(109, 109, 109, 0.5);
    border-radius: vh(4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: vh(12);
    color: white;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;

    &:hover {
      background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
      border: vh(1) solid rgb(105, 8, 29);
      transform: scale(1.02);
    }

    &:active {
      transform: scale(0.98);
    }

    img {
      width: 90%;
      height: 90%;
      object-fit: contain;
    }

    &.active {
      background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
      border: vh(1) solid rgb(105, 8, 29);
    }
  }
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: vh(10);

  overflow-x: hidden;
  overflow-y: auto;
}

// sante
.sante {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: vh(10);

  &__field {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: vh(5);
  }

  &__label {
    font-size: vh(16);
    font-weight: 500;
    color: white;
  }

  &__select {
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    line-height: 1.5;
    border: 1px solid #ccc;
    border-radius: 0.375rem;
    appearance: none;
    background: #202020;
    border: vh(1) solid rgba(109, 109, 109, 0.5);
    color: white;
    border-radius: vh(4);
    cursor: pointer;
    transition: border-color 0.2s;

    &:disabled {
      background-color: #f5f5f5;
      cursor: not-allowed;
      color: #999;
    }
  }

  &__textarea {
    width: 100%;
    padding: 0.5rem;
    font-size: 1rem;
    line-height: 1.5;
    background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
    border: vh(1) solid rgba(109, 109, 109, 0.5);
    color: white;
    border-radius: vh(4);
    resize: vertical;
    font-size: vh(12);
    transition: border-color 0.2s;

    &:focus {
      outline: none;
      background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
      border: vh(1) solid rgb(105, 8, 29);
    }
  }
}

// bg style
.bg-style {
  position: relative;
  background: linear-gradient(180deg, #000000bf -30%, #3f3d3d6b), #0000009c;
  border-radius: vh(4);
  box-shadow: 0 0 vh(5) rgba(0, 0, 0, 0.25);
}

.creator-cam {
  position: absolute;
  width: vh(400);
  height: vh(96);
  padding: vh(15);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: vh(10);
  transform: translate(-50%, -50%);
  top: 10%;
  left: 50%;

  &__item {
    flex: 1;
    height: vh(70);
    background: linear-gradient(180deg, #202020 0%, #4a4848 100%);
    border: vh(1) solid rgba(109, 109, 109, 0.5);
    border-radius: vh(4);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: vh(12);
    color: white;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;

    &:hover {
      background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
      border: vh(1) solid rgb(105, 8, 29);
      transform: scale(1.02);
    }

    &:active {
      transform: scale(0.98);
    }

    img {
      width: 50%;
      height: 50%;
      object-fit: contain;
    }

    &.active {
      background: linear-gradient(180deg, #b41034 0%, #4e0717 100%);
      border: vh(1) solid rgb(105, 8, 29);
    }
  }
}
